# ============================================================================
# Streamlit secrets template.
#
# Locally:
#   Streamlit reads from this file when present at:
#     streamlit_app/.streamlit/secrets.toml
#   But we ALSO support loading from the project root .env (which is what
#   our app does). Use whichever feels natural — both work.
#
# On Streamlit Cloud:
#   Paste this same content (with real values) into:
#     App settings → Secrets
#   Streamlit Cloud injects them as environment variables automatically.
# ============================================================================

SNOWFLAKE_ACCOUNT = "ILZECKL-DBC00026"
SNOWFLAKE_USER = "DEVASHREEPAWAR"
SNOWFLAKE_PASSWORD = "your_password_here"
SNOWFLAKE_ROLE = "ACCOUNTADMIN"
SNOWFLAKE_WAREHOUSE = "COMPUTE_WH"
SNOWFLAKE_DATABASE = "SUPPLY_CHAIN"

OPENAI_API_KEY = "sk-proj-your_key_here"
OPENAI_MODEL = "gpt-4o-mini"
