# ============================================================================
# .env.example  —  TEMPLATE FILE (safe to commit)
#
# Copy this file to .env (which is gitignored) and fill in real values:
#     cp .env.example .env
#
# NEVER commit the real .env. It is excluded by .gitignore.
# ============================================================================

# ---- Snowflake ----
# Account identifier: find at Snowflake → profile (bottom left) → Account
# Format: <ORG>-<ACCOUNT>, e.g. ILZECKL-DBC00026
SNOWFLAKE_ACCOUNT=<your_account_identifier>

# Your Snowflake login name (NOT your email — the "Login name" field)
SNOWFLAKE_USER=<your_login_name>

# The password you set during Snowflake signup
SNOWFLAKE_PASSWORD=<your_password>

# Default warehouse for trial accounts is COMPUTE_WH
# Verify at: Snowflake → Admin → Warehouses
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# Default role for trial accounts is ACCOUNTADMIN
SNOWFLAKE_ROLE=ACCOUNTADMIN

# Database & schema (dbt will create these on first run)
SNOWFLAKE_DATABASE=SUPPLY_CHAIN
SNOWFLAKE_SCHEMA=DBT_DEV

# ---- OpenAI (for the Streamlit LLM app, Phase 3) ----
# Get from: https://platform.openai.com/api-keys
# Starts with sk-proj- or sk-
OPENAI_API_KEY=<your_openai_api_key>

# Model to use for NL → SQL conversion
# gpt-4o-mini is recommended: cheap (~$0.15 per 1M input tokens), fast, accurate enough
OPENAI_MODEL=gpt-4o-mini
